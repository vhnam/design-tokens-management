{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/db/(.*)$",
    "",
    "^@/integrations/(.*)$",
    "",
    "^@/lib/(.*)$",
    "",
    "^@/components/primitives/(.*)$",
    "",
    "^@/components/composites/(.*)$",
    "^[./]"
  ],
  "importOrderTypeScriptVersion": "5.9.3",
  "importOrderCaseSensitive": false
}
