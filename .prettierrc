{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "^@/constants/(.*)$",
    "^@/db(/.*)?$",
    "^@/integrations/(.*)$",
    "^@/lib/(.*)$",
    "^@/queries/(.*)$",
    "^@/enums/(.*)$",
    "^@/types/(.*)$",
    "^@/schemas/(.*)$",
    "^@/stores/(.*)$",
    "^@/layouts/(.*)$",
    "^@/features/(.*)$",
    "^@/components/primitives/(.*)$",
    "^@/components/composites/(.*)$",
    "^[./]",
    "@/styles.css"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
