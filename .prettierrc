{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": ["^@/(.*)$", "^@/db/(.*)$", "^@/integrations/(.*)$", "^[./]"],
  "importOrderTypeScriptVersion": "5.9.3",
  "importOrderCaseSensitive": false
}
